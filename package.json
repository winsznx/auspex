{
  "name": "auspex",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Solana smart-transaction stack that streams live mainnet telemetry, asks an AI control plane for bounded Jito bid policy, and constructs verifiable bundle bytes.",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/index.js",
    "dev": "node --watch --experimental-strip-types --disable-warning=ExperimentalWarning src/index.ts",
    "verify:day0": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-day0.ts",
    "verify:c1": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-c1-ws.ts",
    "verify:c2": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-c2.ts",
    "verify:c3": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-c3.ts",
    "verify:c4": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-c4.ts",
    "verify:c5": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-c5.ts",
    "verify:evidence": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-evidence.ts",
    "doctor:env": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/doctor-env.ts",
    "judge:demo": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/judge-demo.ts",
    "run:evidence": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/run-evidence.ts",
    "run:ab": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/index.ts --mode=ab",
    "fault:blockhash": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/index.ts --inject=blockhash-expiry"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@triton-one/yellowstone-grpc": "^5.0.9",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "jito-js-rpc": "^0.2.2",
    "pino": "^9.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0"
  }
}
