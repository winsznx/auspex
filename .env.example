# Auspex environment — copy to .env and fill with REAL mainnet values.
# NEVER commit .env. Secrets live here locally and in Railway service variables only.
# Every value is a real mainnet credential/endpoint — Auspex uses no mocks and no devnet.

# --- D1: Yellowstone gRPC (Triton "Dragon's Mouth", v5) — data-plane ingest (C1) ---
# Claim SolInfra credits (incl. Yellowstone gRPC) via https://t.me/superteamng
YELLOWSTONE_GRPC_ENDPOINT=https://your-yellowstone-endpoint:443
YELLOWSTONE_X_TOKEN=your-x-token

# --- D2: Mainnet JSON-RPC — blockhash, leader schedule, getBundleStatuses (C2/C4/C6) ---
# Must expose getLatestBlockhash, getLeaderSchedule (and ideally getNextScheduledLeader), getBundleStatuses
SOLANA_RPC_URL=https://your-mainnet-rpc

# --- D3: Funded hot wallet — pays tips + fees (real SOL, ~0.1 SOL covers a full A/B run) ---
# base58-encoded secret key. NEVER commit. Tips are tiny self-transfers (~0.00001–0.001 SOL).
HOT_WALLET_SECRET_KEY=your-base58-secret-key

# --- D4: Jito regional block engine — bundle submit + getTipAccounts (C5) ---
# Pick the lowest-latency region from the Railway region (ny | slc | amsterdam | dublin |
# frankfurt | london | singapore | tokyo). Decide by measured latency; record in memory.
JITO_BLOCK_ENGINE_URL=https://ny.mainnet.block-engine.jito.wtf

# --- D5: Jito tip-floor — live percentiles for baseline + agent inputs (C3) [public, no auth] ---
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor

# --- Control plane (C8/C9) — the tip-intelligence agent ---
ANTHROPIC_API_KEY=your-anthropic-api-key
TIP_AGENT_MODEL=claude-opus-4-8
